YOUTUBE_API_KEY=
NEWS_API_KEY=
GUARDIAN_API_KEY=
NYT_API_KEY=

# Brave Search API — web search generalista con indice indipendente.
# Piano gratuito "Data for AI" Free: 2.000 query/mese, 1 query/sec.
# Registrazione: https://api-dashboard.search.brave.com/
BRAVE_API_KEY=

# Bluesky — richiesto per la ricerca post (l'endpoint pubblico non è più accessibile anonimamente).
# Crea una App Password su: https://bsky.app/settings/app-passwords
# NON usare la password principale dell'account.
# BLUESKY_HANDLE: il tuo handle completo (es. tuo.handle.bsky.social)
# BLUESKY_APP_PASSWORD: nel formato xxxx-xxxx-xxxx-xxxx
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Stack Exchange — opzionale (gratuita, registrazione immediata).
# Senza key: 300 req/giorno per IP. Con key: 10.000 req/giorno.
# Registrazione: https://stackapps.com/apps/oauth/register
STACKEXCHANGE_API_KEY=

# Mastodon — access token opzionale (app-level o user-level).
# Il token è SPECIFICO dell'istanza dove è stato creato (es. mastodon.social).
# Senza token: solo ricerca per hashtag. Con token: ricerca full-text sugli statuses.
# Per creare un token app-level su mastodon.social:
#   1. Registrati su https://mastodon.social
#   2. Preferences → Development → New Application (scope: read)
#   3. Copia "Your access token"
MASTODON_ACCESS_TOKEN=
# Istanza su cui il token è stato creato (default: mastodon.social)
MASTODON_TOKEN_INSTANCE=mastodon.social

# Istanze Mastodon da interrogare (lista separata da virgole).
# Default: mastodon.social,mastodon.online,techhub.social
# MASTODON_INSTANCES=mastodon.social,mastodon.online,techhub.social

# Istanze Lemmy da interrogare (lista separata da virgole).
# Default: lemmy.world,lemmy.ml,sh.itjust.works
# LEMMY_INSTANCES=lemmy.world,lemmy.ml,sh.itjust.works

# HuggingFace token (opzionale ma consigliato per l'enrichment NLP).
# Senza token: rate limit ridotto su HuggingFace Hub durante il download del modello.
# Con token: rate limit più alto e download più veloce del modello XLM-RoBERTa.
# Ottenibile su: https://huggingface.co/settings/tokens (piano gratuito sufficiente)
HF_TOKEN=
